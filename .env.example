# Environment Configuration Template
#
# To use this file:
# 1. Copy this file to .env: cp .env.example .env
# 2. Update the values below with your actual configuration
# 3. Never commit .env to version control
#

# Anthropic API Configuration
# Option 1: Direct Anthropic API (default)
# Required for pre-annotation functionality
ANTHROPIC_API_KEY=your_api_key_here

# Option 2: AWS Bedrock (alternative to direct API)
# If AWS_BEARER_TOKEN_BEDROCK is set, Bedrock will be used instead of direct API
# AWS_BEARER_TOKEN_BEDROCK=your_bearer_token_here
# AWS_REGION=us-east-1

# LLM Configuration
# Model to use for annotation generation
# For direct API: claude-sonnet-4-5, claude-opus-4, etc.
# For Bedrock: anthropic.claude-sonnet-4-0-v1, etc.
TEXTRACTOR_LLM_MODEL=claude-sonnet-4-5

# Fuzzy matching threshold for span validation (0-100)
TEXTRACTOR_FUZZY_THRESHOLD=90

# Optional: Override document root
# Defaults to Docker volume: /app/data/documents
# TEXTRACTOR_DOC_ROOT=/app/data/documents
