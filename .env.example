# Environment Configuration Template
#
# To use this file:
# 1. Copy this file to .env: cp .env.example .env
# 2. Update the values below with your actual configuration
# 3. Never commit .env to version control
#

# Anthropic API Configuration
# Option 1: Direct Anthropic API (default)
# Required for pre-annotation functionality
ANTHROPIC_API_KEY=your_api_key_here

# Option 2: AWS Bedrock (alternative to direct API)
# If AWS_BEARER_TOKEN_BEDROCK is set, Bedrock will be used instead of direct API
# AWS_BEARER_TOKEN_BEDROCK=your_bearer_token_here
# AWS_REGION=us-east-1

# LLM Configuration
# Model to use for annotation generation
# For direct API: claude-sonnet-4-5, claude-opus-4, etc.
# For Bedrock: anthropic.claude-sonnet-4-0-v1, etc.
TEXTRACTOR_LLM_MODEL=claude-sonnet-4-5

# LLM generation parameters
TEXTRACTOR_LLM_MAX_TOKENS_EXTRACT=4096
TEXTRACTOR_LLM_MAX_TOKENS_ANNOTATE=16384
TEXTRACTOR_LLM_TEMPERATURE=0.0

# Fuzzy matching threshold for span validation (0-100)
TEXTRACTOR_FUZZY_THRESHOLD=90

# Server Configuration
TEXTRACTOR_HOST=0.0.0.0
TEXTRACTOR_PORT=8000

# CORS Configuration
# Comma-separated list of allowed origins
TEXTRACTOR_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Optional: Override document root
# Defaults to ./data/documents
TEXTRACTOR_DOC_ROOT=./data/documents

# Optional: Override SNOMED CT directory
# Defaults to ./data/terminology/SnomedCT
TEXTRACTOR_SNOMED_DIR=./data/terminology/SnomedCT

# Optional: ICD-10-CM flat file path (CMS download)
# Defaults to ./data/terminology/icd10cm_codes.txt
TEXTRACTOR_ICD10CM_FILE=./data/terminology/icd10cm_codes.txt

# Optional: Override ICD-10-CM SQLite database path
# Defaults to alongside TEXTRACTOR_ICD10CM_FILE (icd10cm.db)
# In Docker, set to a writable volume path (e.g. /app/data/icd10cm.db)
# TEXTRACTOR_ICD10CM_DB_PATH=/app/data/icd10cm.db
